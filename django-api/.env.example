# Django core — REQUIRED, no default
SECRET_KEY=your-secret-key-here

# Enable debug mode (default: True in dev, must be False in production)
DEBUG=True

# PostgreSQL connection
# DB_NAME: database name (default: tournament_platform)
DB_NAME=tournament_platform

# DB_USER: PostgreSQL user — REQUIRED, no default
DB_USER=your_db_user

# DB_PASSWORD: PostgreSQL password — REQUIRED, no default
DB_PASSWORD=your_db_password

# DB_HOST: host where PostgreSQL is running (default: localhost)
DB_HOST=localhost

# DB_PORT: port PostgreSQL listens on (default: 5432)
DB_PORT=5432

# CORS — comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5073

# DRF pagination page size (default: 20)
PAGE_SIZE=20
