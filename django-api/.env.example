# PostgreSQL connection settings
# Copy this file to .env and fill in real values before running the app.

# Database name (default: tournament_platform)
DB_NAME=tournament_platform

# PostgreSQL user — REQUIRED, no default
DB_USER=your_db_user

# PostgreSQL password — REQUIRED, no default
DB_PASSWORD=your_db_password

# Host where PostgreSQL is running (default: localhost)
DB_HOST=localhost

# Port PostgreSQL listens on (default: 5432)
DB_PORT=5432
