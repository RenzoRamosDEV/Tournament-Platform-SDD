# Django
SECRET_KEY=change-me-to-a-long-random-string-50-chars
DEBUG=True
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Database (shared by django-api and java-auth)
DB_NAME=tournament_platform
DB_USER=tournament_user
DB_PASSWORD=change-me-db-password
DB_HOST=postgres
DB_PORT=5432

# PostgreSQL container variables (must match DB_* above)
POSTGRES_DB=tournament_platform
POSTGRES_USER=tournament_user
POSTGRES_PASSWORD=change-me-db-password

# Django → auth-service
AUTH_SERVICE_URL=http://java-auth:8080

# Java auth-service
JWT_SECRET=change-me-to-a-secret-of-at-least-32-characters
SPRING_DATASOURCE_USERNAME=tournament_user
SPRING_DATASOURCE_PASSWORD=change-me-db-password

# Kafka
KAFKA_BROKER_ID=1
